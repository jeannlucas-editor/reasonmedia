const axios = require("axios");

// ─── Ensure user is authenticated ────────────────────────────
async function requireAuth(req, res, next) {
  if (!req.session.accessToken) {
    return res.status(401).json({ error: "Not authenticated", code: "AUTH_REQUIRED" });
  }

  // Auto-refresh if token is about to expire (within 5 minutes)
  if (req.session.tokenExpiry && req.session.tokenExpiry - Date.now() < 300000) {
    try {
      await refreshToken(req);
    } catch {
      return res.status(401).json({ error: "Session expired", code: "SESSION_EXPIRED" });
    }
  }

  next();
}

// ─── Refresh token helper ─────────────────────────────────────
async function refreshToken(req) {
  if (!req.session.refreshToken) throw new Error("No refresh token");

  const credentials = Buffer.from(
    `${process.env.CANVA_CLIENT_ID}:${process.env.CANVA_CLIENT_SECRET}`
  ).toString("base64");

  const { data } = await axios.post(
    "https://api.canva.com/rest/v1/oauth/token",
    new URLSearchParams({
      grant_type: "refresh_token",
      refresh_token: req.session.refreshToken,
    }),
    {
      headers: {
        Authorization: `Basic ${credentials}`,
        "Content-Type": "application/x-www-form-urlencoded",
      },
    }
  );

  req.session.accessToken = data.access_token;
  req.session.tokenExpiry = Date.now() + data.expires_in * 1000;
}

module.exports = { requireAuth };
